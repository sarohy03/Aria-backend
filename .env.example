OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
COMPOSIO_API_KEY=

# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Optional: extra CORS origins (comma-separated), e.g. Vercel preview URLs
# Extra CORS origins (comma-separated). Vercel preview URLs match CORS_ORIGIN_REGEX by default.
# CORS_ORIGINS=https://aria-git-main-yourteam.vercel.app

GMAIL_FETCH_MAX_RESULTS=15

# Firebase Admin (service account)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key; use literal \n for newlines in Render/Vercel env UI
FIREBASE_PRIVATE_KEY=
